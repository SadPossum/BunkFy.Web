{
  "name": "@sadpossum/bunkfy-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "pnpm typecheck && vite build",
    "contracts:generate": "powershell -NoProfile -File ../../eng/update-web-contracts.ps1",
    "contracts:check": "powershell -NoProfile -File ../../eng/update-web-contracts.ps1 -Check -NoBuild",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "daisyui": "^5.6.16",
    "eslint": "^9.39.0",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.46.0",
    "vite": "^8.1.3",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  }
}
